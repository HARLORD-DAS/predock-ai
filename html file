function switchTab(name,btn){
  ['summary','protein','ligand','lipinski','pipeline'].forEach(function(t){
    var el=document.getElementById('rt-'+t);
    if(el) el.style.display=t===name?'':'none';
  });
  document.querySelectorAll('.res-tab').forEach(function(b){b.classList.remove('active')});
  btn.classList.add('active');
}

function getInterp(result,pf,lf){
  var s=result.docking_score,p=result.binding_probability;
  if(s<=-8) return 'Score of <strong>'+s+' kcal/mol</strong> indicates strong predicted binding affinity ('+p+'%). The '+pf.pocket_residues+'-residue binding pocket and ligand properties (MW '+lf.mol_weight+' Da, LogP '+lf.logp+') are well-matched. Recommend validation with AutoDock Vina and wet-lab assay.';
  if(s<=-6) return 'Score of <strong>'+s+' kcal/mol</strong> suggests moderate affinity ('+p+'%). Structural optimisation — enhancing hydrophobic contacts or H-bond geometry — may improve potency. Scaffold is '+(lf.lipinski_pass?'drug-like (Lipinski compliant)':'non-drug-like (Lipinski violations)')+'.';
  return 'Score of <strong>'+s+' kcal/mol</strong> indicates weak or negligible binding ('+p+'%). The ligand likely lacks complementarity to the '+pf.pocket_residues+'-residue pocket. Consider scaffold redesign or targeting an alternative binding site.';
}
