<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PreDock AI — Protein–Ligand Binding Predictor</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=DM+Sans:wght@300;400;500;600&family=DM+Serif+Display&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/3Dmol/2.0.3/3Dmol-min.js"></script>
<style>
:root{
  --bg:#0a0e14;--bg2:#111720;--bg3:#171f2e;
  --surface:#1a2436;
  --border:rgba(99,179,237,0.12);--border2:rgba(99,179,237,0.22);
  --accent:#38bdf8;--accent2:#0ea5e9;
  --green:#34d399;--amber:#fbbf24;--red:#f87171;
  --text:#e2eaf4;--text2:#8ea8c3;--text3:#4e6a85;
  --mono:'IBM Plex Mono',monospace;--sans:'DM Sans',sans-serif;--serif:'DM Serif Display',serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:14px}
body{font-family:var(--sans);background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(56,189,248,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(56,189,248,.025) 1px,transparent 1px);background-size:44px 44px;pointer-events:none;z-index:0}

.header{position:sticky;top:0;z-index:200;background:rgba(10,14,20,.94);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);padding:0 28px;height:54px;display:flex;align-items:center;justify-content:space-between}
.logo-row{display:flex;align-items:center;gap:10px}
.logo-icon{width:30px;height:30px;background:linear-gradient(135deg,var(--accent2),var(--green));border-radius:8px;display:flex;align-items:center;justify-content:center}
.logo-icon svg{width:15px;height:15px;fill:white}
.logo-text{font-family:var(--serif);font-size:18px;letter-spacing:-.01em}
.logo-text span{color:var(--accent)}
.hbadges{display:flex;gap:6px}
.hbadge{font-family:var(--mono);font-size:10px;color:var(--text3);border:1px solid var(--border);border-radius:4px;padding:2px 7px}
.hbadge.live{color:var(--green);border-color:rgba(52,211,153,.3);background:rgba(52,211,153,.06)}

.app{position:relative;z-index:1;display:grid;grid-template-columns:360px 1fr;min-height:calc(100vh - 54px)}

.sidebar{background:var(--bg2);border-right:1px solid var(--border);padding:20px 18px;display:flex;flex-direction:column;gap:18px;overflow-y:auto;max-height:calc(100vh - 54px);position:sticky;top:54px}
.s-label{font-family:var(--mono);font-size:10px;color:var(--text3);letter-spacing:.1em;text-transform:uppercase;margin-bottom:8px;display:flex;align-items:center;gap:6px}
.s-label::after{content:'';flex:1;height:1px;background:var(--border)}

.upload-zone{border:1px dashed var(--border2);border-radius:10px;padding:16px;text-align:center;cursor:pointer;transition:all .2s;background:var(--bg3)}
.upload-zone:hover{border-color:var(--accent);background:rgba(56,189,248,.04)}
.upload-zone.loaded{border-color:var(--green);border-style:solid;background:rgba(52,211,153,.05)}
.upload-icon{font-size:20px;margin-bottom:5px}
.upload-text{font-size:12px;color:var(--text2)}
.upload-file{font-family:var(--mono);font-size:11px;color:var(--green);margin-top:4px}

.mol-thumb{margin-top:8px;border-radius:8px;overflow:hidden;border:1px solid var(--border);background:#060a10;position:relative;display:none}
.mol-thumb-viewer{width:100%;height:160px}
.mol-thumb-label{position:absolute;bottom:6px;left:8px;font-family:var(--mono);font-size:9px;color:var(--text3);background:rgba(10,14,20,.75);padding:2px 6px;border-radius:3px;pointer-events:none}
.thumb-ctrls{position:absolute;top:5px;right:5px;display:flex;gap:3px}
.tc-btn{background:rgba(10,14,20,.75);border:1px solid var(--border2);border-radius:4px;color:var(--text2);font-size:10px;padding:2px 6px;cursor:pointer;font-family:var(--mono);transition:all .15s}
.tc-btn:hover{color:var(--accent);border-color:var(--accent)}

.pdb-peek{font-family:var(--mono);font-size:9px;color:var(--text3);background:var(--bg);border-radius:6px;padding:7px 9px;margin-top:7px;line-height:1.7;max-height:62px;overflow:hidden;border:1px solid var(--border);display:none}

.tab-bar{display:flex;gap:2px;background:var(--bg);border-radius:8px;padding:3px;border:1px solid var(--border)}
.tab-btn{flex:1;border:none;background:transparent;color:var(--text3);font-family:var(--sans);font-size:12px;padding:5px 4px;cursor:pointer;border-radius:5px;transition:all .15s}
.tab-btn.active{background:var(--surface);color:var(--accent);font-weight:500}

textarea{width:100%;background:var(--bg);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:var(--mono);font-size:11px;padding:9px 11px;resize:vertical;transition:border-color .15s;line-height:1.6;min-height:76px}
textarea:focus{outline:none;border-color:var(--accent2)}

.ex-grid{display:flex;flex-direction:column;gap:3px}
.ex-btn{text-align:left;background:var(--bg3);border:1px solid var(--border);border-radius:6px;padding:6px 9px;font-family:var(--mono);font-size:10px;color:var(--text3);cursor:pointer;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;transition:all .15s}
.ex-btn:hover{border-color:var(--accent2);color:var(--accent)}
.ex-name{font-family:var(--sans);font-size:10px;color:var(--text3);margin-left:5px;opacity:.55}
.demo-btn{width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:7px;color:var(--text2);font-family:var(--sans);font-size:12px;padding:7px;cursor:pointer;transition:all .15s;margin-top:5px}
.demo-btn:hover{border-color:var(--green);color:var(--green);background:rgba(52,211,153,.05)}

.run-btn{width:100%;padding:11px;background:linear-gradient(135deg,var(--accent2),#0284c7);border:none;border-radius:10px;color:white;font-family:var(--sans);font-size:14px;font-weight:600;cursor:pointer;transition:all .2s;letter-spacing:.02em}
.run-btn:hover:not(:disabled){filter:brightness(1.1)}
.run-btn:disabled{background:var(--surface);color:var(--text3);cursor:not-allowed}
.run-btn.running{background:linear-gradient(135deg,#0f766e,#059669)}
.spinner{display:inline-block;width:13px;height:13px;border:2px solid rgba(255,255,255,.3);border-top-color:white;border-radius:50%;animation:spin .65s linear infinite;vertical-align:middle;margin-right:6px}
@keyframes spin{to{transform:rotate(360deg)}}

.main{padding:24px;overflow-y:auto;max-height:calc(100vh - 54px)}

.placeholder{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:60vh;gap:14px;color:var(--text3);text-align:center}
.ph-ring{width:88px;height:88px;border:1px solid var(--border);border-radius:50%;display:flex;align-items:center;justify-content:center;position:relative;animation:rotRing 14s linear infinite}
.ph-ring::before{content:'';position:absolute;width:56px;height:56px;border:1px solid var(--border);border-radius:50%}
.ph-ring::after{content:'';position:absolute;width:24px;height:24px;border:1px solid var(--border);border-radius:50%}
@keyframes rotRing{to{transform:rotate(360deg)}}
.placeholder h3{font-family:var(--serif);font-size:22px;color:var(--text2)}
.placeholder p{font-size:13px;max-width:360px;line-height:1.75}

.loading-wrap{padding:4px 0}
.agent-hdr{font-family:var(--mono);font-size:10px;color:var(--text3);margin-bottom:12px;letter-spacing:.08em}
.agent-item{display:flex;align-items:center;gap:10px;padding:9px 13px;border-radius:8px;margin-bottom:5px;background:var(--bg3);border:1px solid var(--border);transition:all .3s}
.agent-item.running{border-color:var(--amber);background:rgba(251,191,36,.05)}
.agent-item.done{border-color:var(--green);background:rgba(52,211,153,.05)}
.agent-dot{width:7px;height:7px;border-radius:50%;background:var(--text3);flex-shrink:0;transition:background .3s}
.agent-item.running .agent-dot{background:var(--amber);animation:pulse 1s infinite}
.agent-item.done .agent-dot{background:var(--green)}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.agent-name{font-family:var(--mono);font-size:11px;color:var(--text2)}
.agent-item.done .agent-name{color:var(--text)}
.agent-stat{font-size:10px;color:var(--text3);margin-left:auto;text-align:right;max-width:240px}
.agent-item.done .agent-stat{color:var(--green)}

.results{display:flex;flex-direction:column;gap:14px;animation:fadeUp .4s ease}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}

.score-card{border-radius:14px;padding:22px 26px;border:1px solid;display:grid;grid-template-columns:1fr auto;align-items:center;gap:16px}
.score-card.strong{background:rgba(52,211,153,.07);border-color:rgba(52,211,153,.28)}
.score-card.moderate{background:rgba(251,191,36,.07);border-color:rgba(251,191,36,.28)}
.score-card.weak{background:rgba(248,113,113,.07);border-color:rgba(248,113,113,.28)}
.score-eyebrow{font-family:var(--mono);font-size:10px;letter-spacing:.1em;margin-bottom:7px}
.score-card.strong .score-eyebrow{color:var(--green)}
.score-card.moderate .score-eyebrow{color:var(--amber)}
.score-card.weak .score-eyebrow{color:var(--red)}
.score-number{font-family:var(--serif);font-size:42px;letter-spacing:-.02em;line-height:1}
.score-card.strong .score-number{color:var(--green)}
.score-card.moderate .score-number{color:var(--amber)}
.score-card.weak .score-number{color:var(--red)}
.score-unit{font-size:15px;opacity:.6;margin-left:4px}
.score-sub{font-size:12px;color:var(--text2);margin-top:5px}
.strength-badge{display:inline-flex;align-items:center;gap:6px;padding:5px 14px;border-radius:20px;font-size:13px;font-weight:600;letter-spacing:.04em}
.strength-badge.strong{background:rgba(52,211,153,.15);color:var(--green);border:1px solid rgba(52,211,153,.3)}
.strength-badge.moderate{background:rgba(251,191,36,.15);color:var(--amber);border:1px solid rgba(251,191,36,.3)}
.strength-badge.weak{background:rgba(248,113,113,.15);color:var(--red);border:1px solid rgba(248,113,113,.3)}
.bdot{width:6px;height:6px;border-radius:50%}
.strong .bdot{background:var(--green)}
.moderate .bdot{background:var(--amber)}
.weak .bdot{background:var(--red)}

/* ── 3D VIEWER ── */
.viewer-panel{background:var(--bg2);border:1px solid var(--border);border-radius:14px;overflow:hidden}
.viewer-topbar{display:flex;align-items:center;justify-content:space-between;padding:10px 16px;border-bottom:1px solid var(--border);background:var(--bg3);flex-wrap:wrap;gap:8px}
.viewer-title{font-family:var(--mono);font-size:11px;color:var(--text2)}
.viewer-controls{display:flex;gap:5px;flex-wrap:wrap}
.vc-btn{background:var(--bg);border:1px solid var(--border);border-radius:6px;color:var(--text2);font-size:11px;padding:3px 10px;cursor:pointer;font-family:var(--mono);transition:all .15s}
.vc-btn:hover{color:var(--accent);border-color:var(--accent)}
.vc-btn.active{background:rgba(56,189,248,.1);color:var(--accent);border-color:rgba(56,189,248,.4)}
.viewer-stage{position:relative;height:380px;background:#060a10}
#mol-viewer{width:100%;height:100%}
.vloader{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;background:#060a10;z-index:10;gap:10px}
.vl-spin{width:28px;height:28px;border:2px solid rgba(56,189,248,.2);border-top-color:var(--accent);border-radius:50%;animation:spin .7s linear infinite}
.vl-txt{font-family:var(--mono);font-size:11px;color:var(--text3)}
.viewer-footer{display:flex;gap:14px;padding:9px 16px;border-top:1px solid var(--border);flex-wrap:wrap;align-items:center}
.leg-item{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--text3);font-family:var(--mono)}
.leg-dot{width:8px;height:8px;border-radius:50%}
.viewer-hint{margin-left:auto;font-size:10px;color:var(--text3);opacity:.5}

.metrics-row{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.metric-card{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:13px 15px}
.metric-label{font-family:var(--mono);font-size:9px;color:var(--text3);letter-spacing:.1em;text-transform:uppercase;margin-bottom:5px}
.metric-value{font-family:var(--serif);font-size:26px;color:var(--text);line-height:1}
.metric-sub{font-size:10px;color:var(--text3);margin-top:3px}
.pbar{height:3px;background:var(--bg);border-radius:2px;margin-top:7px;overflow:hidden}
.pfill{height:100%;border-radius:2px;transition:width .8s cubic-bezier(.16,1,.3,1)}
.pfill-g{background:var(--green)}
.pfill-b{background:var(--accent)}

.res-tabs{display:flex;gap:2px;background:var(--bg);border-radius:9px;padding:3px;border:1px solid var(--border);margin-bottom:13px}
.res-tab{flex:1;border:none;background:transparent;color:var(--text3);font-family:var(--sans);font-size:11.5px;padding:6px 4px;cursor:pointer;border-radius:6px;transition:all .15s}
.res-tab.active{background:var(--surface);color:var(--accent);font-weight:500}
.info-card{background:var(--bg2);border:1px solid var(--border);border-radius:12px;padding:16px 18px}
.info-title{font-family:var(--mono);font-size:10px;color:var(--text3);letter-spacing:.1em;text-transform:uppercase;margin-bottom:11px}
.feat-tbl{width:100%;border-collapse:collapse;font-size:12px}
.feat-tbl tr{border-bottom:1px solid var(--border)}
.feat-tbl tr:last-child{border-bottom:none}
.feat-tbl td{padding:6px 0}
.feat-tbl td:first-child{font-family:var(--mono);font-size:11px;color:var(--text2);width:55%}
.feat-tbl td:last-child{text-align:right;color:var(--text);font-weight:500}
.lip-row{display:flex;align-items:center;justify-content:space-between;padding:7px 0;border-bottom:1px solid var(--border);font-size:12px}
.lip-row:last-child{border-bottom:none}
.lip-rule{color:var(--text2)}
.lip-val{font-family:var(--mono);font-size:11px;color:var(--text3)}
.lip-pass{color:var(--green);font-weight:600}
.lip-fail{color:var(--red);font-weight:600}
.interp-box{background:var(--bg3);border-left:3px solid var(--accent2);border-radius:0 8px 8px 0;padding:13px 15px;font-size:13px;color:var(--text2);line-height:1.75;margin-bottom:12px}
.interp-box.strong{border-color:var(--green)}
.interp-box.moderate{border-color:var(--amber)}
.interp-box.weak{border-color:var(--red)}
.pipe-item{display:flex;align-items:flex-start;gap:9px;padding:7px 0}
.pipe-num{font-family:var(--mono);font-size:10px;color:var(--accent);background:rgba(56,189,248,.1);border:1px solid rgba(56,189,248,.2);border-radius:4px;padding:1px 5px;flex-shrink:0;margin-top:1px}
.pipe-agent{font-family:var(--mono);font-size:11px;color:var(--text)}
.pipe-desc{font-size:11px;color:var(--text3);margin-top:2px}
.pipe-div{width:1px;height:10px;background:var(--border);margin:0 0 0 24px}
.code-block{background:var(--bg);border:1px solid var(--border);border-radius:7px;padding:11px 13px;font-family:var(--mono);font-size:10px;color:var(--text2);line-height:1.9;margin-top:11px}
.code-key{color:var(--accent)}
.code-val{color:var(--green)}
.disclaimer{font-size:11px;color:var(--text3);text-align:center;padding:7px 0 3px;border-top:1px solid var(--border);margin-top:2px}

@media(max-width:900px){
  .app{grid-template-columns:1fr}
  .sidebar{position:static;max-height:none;border-right:none;border-bottom:1px solid var(--border)}
  .main{max-height:none}
  .metrics-row{grid-template-columns:1fr 1fr}
  .score-card{grid-template-columns:1fr}
  .viewer-stage{height:280px}
}
</style>
</head>
<body>
<header class="header">
  <div class="logo-row">
    <div class="logo-icon"><svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.93 0 3.5 1.57 3.5 3.5S13.93 12 12 12 8.5 10.43 8.5 8.5 10.07 5 12 5zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/></svg></div>
    <span class="logo-text">Pre<span>Dock</span> AI</span>
  </div>
  <div class="hbadges">
    <span class="hbadge">Antigravity v2.0</span>
    <span class="hbadge">GBM Inference</span>
    <span class="hbadge">Multi-Agent</span>
    <span class="hbadge live">● 3D Viewer</span>
  </div>
</header>

<div class="app">
<aside class="sidebar">

  <div>
    <div class="s-label">01 · Protein Input (.pdb)</div>
    <div class="upload-zone" id="pdb-zone" onclick="document.getElementById('pdb-file').click()">
      <div class="upload-icon">⬡</div>
      <div class="upload-text" id="pdb-text">Drop .pdb file or click to upload</div>
      <div class="upload-file" id="pdb-fname" style="display:none"></div>
      <input type="file" id="pdb-file" accept=".pdb" style="display:none" onchange="onPdbFile(this)">
    </div>
    <div class="pdb-peek" id="pdb-peek"></div>
    <div class="mol-thumb" id="pdb-thumb">
      <div class="mol-thumb-viewer" id="pdb-thumb-viewer"></div>
      <div class="mol-thumb-label" id="pdb-thumb-label">cartoon · protein</div>
      <div class="thumb-ctrls">
        <button class="tc-btn" onclick="thumbStyle('cartoon')">cartoon</button>
        <button class="tc-btn" onclick="thumbStyle('surface')">surface</button>
        <button class="tc-btn" onclick="thumbStyle('stick')">stick</button>
      </div>
    </div>
    <button class="demo-btn" onclick="loadDemo()">⬡ Load demo: HIV-1 Protease (4HVP)</button>
  </div>

  <div>
    <div class="s-label">02 · Ligand Input</div>
    <div class="tab-bar" style="margin-bottom:9px">
      <button class="tab-btn active" onclick="setLigMode('smiles',this)">SMILES</button>
      <button class="tab-btn" onclick="setLigMode('sdf',this)">SDF</button>
      <button class="tab-btn" onclick="setLigMode('mol2',this)">MOL2</button>
    </div>
    <div id="smiles-panel">
      <textarea id="smiles-in" placeholder="Paste SMILES string&#10;e.g. CC(=O)Oc1ccccc1C(=O)O"></textarea>
    </div>
    <div id="file-panel" style="display:none">
      <div class="upload-zone" onclick="document.getElementById('lig-file').click()">
        <div class="upload-text" id="lig-text">Drop .sdf or .mol2 file</div>
        <div class="upload-file" id="lig-fname" style="display:none"></div>
        <input type="file" id="lig-file" accept=".sdf,.mol2" style="display:none" onchange="onLigFile(this)">
      </div>
      <div class="mol-thumb" id="lig-thumb" style="margin-top:8px">
        <div class="mol-thumb-viewer" id="lig-thumb-viewer"></div>
        <div class="mol-thumb-label">stick · ligand</div>
      </div>
    </div>
    <div style="margin-top:9px">
      <div class="s-label" style="margin-bottom:5px">Quick examples</div>
      <div class="ex-grid">
        <button class="ex-btn" onclick="useSMILES('CC(=O)Oc1ccccc1C(=O)O')">CC(=O)Oc1ccccc1C(=O)O <span class="ex-name">aspirin</span></button>
        <button class="ex-btn" onclick="useSMILES('CC(C)Cc1ccc(cc1)C(C)C(=O)O')">CC(C)Cc1ccc(cc1)C(C)C(=O)O <span class="ex-name">ibuprofen</span></button>
        <button class="ex-btn" onclick="useSMILES('CN1C=NC2=C1C(=O)N(C(=O)N2C)C')">CN1C=NC2=C1C(=O)N(C(=O)N2C)C <span class="ex-name">caffeine</span></button>
        <button class="ex-btn" onclick="useSMILES('CC(=O)Nc1ccc(O)cc1')">CC(=O)Nc1ccc(O)cc1 <span class="ex-name">paracetamol</span></button>
        <button class="ex-btn" onclick="useSMILES('c1ccc2c(c1)cc1ccc3cccc4ccc2c1c34')">c1ccc2c(c1)cc1ccc3cccc4ccc2c1c34 <span class="ex-name">pyrene</span></button>
      </div>
    </div>
  </div>

  <button class="run-btn" id="run-btn" onclick="runPrediction()" disabled>Run Prediction</button>
  <div class="disclaimer">⚠ Screening tool only · Not for clinical use · Validate with AutoDock Vina</div>

</aside>

<main class="main">
  <div class="placeholder" id="placeholder">
    <div class="ph-ring">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity=".4">
        <circle cx="12" cy="12" r="3"/><line x1="3" y1="12" x2="9" y2="12"/><line x1="15" y1="12" x2="21" y2="12"/>
        <line x1="12" y1="3" x2="12" y2="9"/><line x1="12" y1="15" x2="12" y2="21"/>
      </svg>
    </div>
    <h3>Awaiting molecular input</h3>
    <p>Upload a PDB protein file and provide a ligand to get binding affinity predictions with live 3D structure visualization.</p>
