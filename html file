      +lipRows.map(function(r){return '<div class="lip-row"><span class="lip-rule">'+r.rule+'</span><span class="lip-val">'+r.val+'</span><span class="'+(r.pass?'lip-pass':'lip-fail')+'">'+(r.pass?'✓ Pass':'✗ Fail')+'</span></div>';}).join('')
      +'<div style="margin-top:11px;font-size:12px;color:var(--text2)">Overall: <strong style="color:'+(lf.lipinski_pass?'var(--green)':'var(--red)')+'">'+( lf.lipinski_pass?'Drug-like — all 4 rules satisfied':'Violates '+lipFails+' rule(s)')+'</strong></div>'
    +'</div>'
