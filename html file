<script>
// ── STATE ──
var pdbContent=null,ligContent=null,ligMode='smiles',ligFileName=null;
var thumbViewer=null,mainViewer=null,ligThumbViewer=null;
window._viewerHovered=false;
window._pocketShown=false;

// ── UI ──
function setLigMode(mode,btn){
  ligMode=mode;
  document.querySelectorAll('.tab-btn').forEach(function(b){b.classList.remove('active')});
  btn.classList.add('active');
  document.getElementById('smiles-panel').style.display=mode==='smiles'?'':'none';
  document.getElementById('file-panel').style.display=mode!=='smiles'?'':'none';
  checkReady();
}
function useSMILES(smi){
  ligMode='smiles';
  document.querySelectorAll('.tab-btn').forEach(function(b,i){b.classList.toggle('active',i===0)});
  document.getElementById('smiles-panel').style.display='';
  document.getElementById('file-panel').style.display='none';
  document.getElementById('smiles-in').value=smi;
  checkReady();
}
document.getElementById('smiles-in').addEventListener('input',checkReady);
function checkReady(){
  var smi=document.getElementById('smiles-in').value.trim();
  var hasLig=ligMode==='smiles'?smi.length>2:ligContent!==null;
  document.getElementById('run-btn').disabled=!(pdbContent&&hasLig);
}

// ── FILE HANDLERS ──
function onPdbFile(inp){
  var f=inp.files[0]; if(!f) return;
  var r=new FileReader();
  r.onload=function(e){
    pdbContent=e.target.result;
    document.getElementById('pdb-fname').textContent='✓ '+f.name;
    document.getElementById('pdb-fname').style.display='block';
    document.getElementById('pdb-text').textContent='Protein file loaded';
    document.getElementById('pdb-zone').classList.add('loaded');
    showPdbPeek(pdbContent);
    initThumb(pdbContent);
    checkReady();
  };
  r.readAsText(f);
}
function showPdbPeek(txt){
  var lines=txt.split('\n').filter(function(l){return l.match(/^(HEADER|REMARK|ATOM|HETATM)/)}).slice(0,5);
  var el=document.getElementById('pdb-peek');
  el.textContent=lines.join('\n');
  el.style.display='block';
}
function onLigFile(inp){
  var f=inp.files[0]; if(!f) return;
  var r=new FileReader();
  r.onload=function(e){
    ligContent=e.target.result;
    ligFileName=f.name;
    document.getElementById('lig-fname').textContent='✓ '+f.name;
    document.getElementById('lig-fname').style.display='block';
    document.getElementById('lig-text').textContent='Ligand file loaded';
    var ext=f.name.split('.').pop().toLowerCase();
    if(ext==='sdf'||ext==='mol2') initLigThumb(ligContent,ext);
    checkReady();
  };
  r.readAsText(f);
}

// ── SIDEBAR THUMBNAIL (PROTEIN) ──
function initThumb(pdbStr){
  var container=document.getElementById('pdb-thumb');
  container.style.display='block';
  var el=document.getElementById('pdb-thumb-viewer');
  el.innerHTML='';
  if(thumbViewer){try{thumbViewer.clear();}catch(e){}}
  thumbViewer=$3Dmol.createViewer($(el),{backgroundColor:'#060a10',antialias:true});
  thumbViewer.addModel(pdbStr,'pdb');
  thumbViewer.setStyle({},{cartoon:{color:'spectrum',opacity:.95}});
  thumbViewer.setStyle({hetflag:true},{stick:{radius:.12,colorscheme:'greenCarbon'}});
  thumbViewer.zoomTo();
  thumbViewer.render();
  if(window._thumbRot) clearInterval(window._thumbRot);
  window._thumbRot=setInterval(function(){
    if(thumbViewer){thumbViewer.rotate(.5,{x:0,y:1,z:0});thumbViewer.render();}
  },50);
}
function thumbStyle(s){
  if(!thumbViewer) return;
  thumbViewer.setStyle({});
  thumbViewer.removeAllSurfaces();
  if(s==='cartoon'){
    thumbViewer.setStyle({hetflag:false},{cartoon:{color:'spectrum',opacity:.95}});
    thumbViewer.setStyle({hetflag:true},{stick:{radius:.12,colorscheme:'greenCarbon'}});
  } else if(s==='surface'){
    thumbViewer.setStyle({hetflag:false},{cartoon:{color:'spectrum',opacity:.2}});
    thumbViewer.addSurface($3Dmol.SurfaceType.VDW,{opacity:.5,colorscheme:{gradient:'rwb'}},{hetflag:false});
    thumbViewer.setStyle({hetflag:true},{stick:{radius:.12,colorscheme:'greenCarbon'}});
  } else if(s==='stick'){
    thumbViewer.setStyle({},{stick:{radius:.08,colorscheme:'chainHetatm'}});
  }
  thumbViewer.render();
  document.getElementById('pdb-thumb-label').textContent=s+' · protein';
}

// ── SIDEBAR THUMBNAIL (LIGAND SDF/MOL2) ──
function initLigThumb(content,fmt){
  var container=document.getElementById('lig-thumb');
  container.style.display='block';
  var el=document.getElementById('lig-thumb-viewer');
  el.innerHTML='';
  if(ligThumbViewer){try{ligThumbViewer.clear();}catch(e){}}
  try{
    ligThumbViewer=$3Dmol.createViewer($(el),{backgroundColor:'#060a10',antialias:true});
    ligThumbViewer.addModel(content,fmt==='mol2'?'mol2':'sdf');
    ligThumbViewer.setStyle({},{stick:{radius:.15,colorscheme:'greenCarbon'},sphere:{radius:.28,colorscheme:'greenCarbon'}});
    ligThumbViewer.zoomTo();
    ligThumbViewer.render();
    if(window._ligRot) clearInterval(window._ligRot);
    window._ligRot=setInterval(function(){
      if(ligThumbViewer){ligThumbViewer.rotate(.8,{x:0,y:1,z:0});ligThumbViewer.render();}
    },60);
  }catch(e){container.style.display='none';}
}

// ── DEMO DATA ──
function loadDemo(){
  var AAS=['PRO','GLN','ILE','THR','LEU','TRP','GLN','ARG','PRO','LEU','VAL','THR','ILE','LYS','ILE','GLY','GLY','GLN','LEU','LYS','GLU','ALA','LEU','LEU','ASP','THR','GLY','ALA','ASP','ASP','THR','VAL','LEU','GLU','GLU','MET','ASN','LEU','PRO','GLY','ARG','TRP','LYS','PRO','LYS','MET','ILE','GLY','GLY','ILE','GLY','GLY','PHE','ILE','LYS','VAL','ARG','GLN','TYR','ASP','GLN','ILE','LEU','ILE','GLU','ILE','CYS','GLY','HIS','LYS','ALA','ILE','GLY','THR','VAL','LEU','VAL','GLY','PRO','THR','PRO','VAL','ASN','ILE','ILE','GLY','ARG','ASN','LEU','LEU','THR','GLN','ILE','GLY','CYS','THR','LEU','ASN','PHE'];
  var lines=['HEADER    HYDROLASE/INHIBITOR             23-JUN-95   1HVR','REMARK    HIV-1 PROTEASE DEMO — PREDOCK AI'];
  for(var i=0;i<50;i++){
    var t=i*.36;
    lines.push(atomLine(i+1,AAS[i%AAS.length],'A',i+1,
      (2.3*Math.cos(t)+18).toFixed(3),(2.3*Math.sin(t)+18).toFixed(3),(i*.54+5).toFixed(3)));
  }
  for(var i=50;i<100;i++){
    var j=i-50;
    lines.push(atomLine(i+1,AAS[i%AAS.length],'A',i+1,
      (j*.36+25).toFixed(3),((j%2)*2.8+22).toFixed(3),(j*.1+35).toFixed(3)));
  }
  for(var i=100;i<150;i++){
    var t=(i-100)*.36;
    lines.push(atomLine(i+1,AAS[i%AAS.length],'A',i+1,
      (2.3*Math.cos(t)+32).toFixed(3),(2.3*Math.sin(t)+14).toFixed(3),((i-100)*.54+5).toFixed(3)));
  }
  var pAA=['ASP','THR','GLY','ILE','PHE','PRO','LEU','VAL','TYR','ASN','ARG','HIS','SER','GLU','LYS'];
  for(var i=0;i<15;i++){
    var ang=(i/15)*2*Math.PI;
    lines.push(atomLine(151+i,pAA[i],'A',151+i,
      (7*Math.cos(ang)+25).toFixed(3),(7*Math.sin(ang)+18).toFixed(3),(22+i*.3).toFixed(3)));
  }
  // HETATM ligand atoms (ibuprofen-like)
  var la=[[' C  ','LIG','A',200,25.0,18.0,22.0],[' N  ','LIG','A',201,27.1,19.2,22.0],
           [' O  ','LIG','A',202,25.8,17.1,23.1],[' C  ','LIG','A',203,23.9,20.3,21.2],
           [' C  ','LIG','A',204,28.2,17.3,21.4],[' S  ','LIG','A',205,26.1,21.4,20.1]];
  la.forEach(function(a){
    lines.push('HETATM'+String(a[3]).padStart(5)+'  '+a[0]+a[1]+' '+a[2]+String(a[3]).padStart(4)+'    '+a[4].toFixed(3).padStart(8)+a[5].toFixed(3).padStart(8)+a[6].toFixed(3).padStart(8)+'  1.00 20.00           '+a[0].trim().charAt(0));
  });
  lines.push('END');
  pdbContent=lines.join('\n');
  document.getElementById('pdb-fname').textContent='✓ 1hvr_demo.pdb';
  document.getElementById('pdb-fname').style.display='block';
  document.getElementById('pdb-text').textContent='Demo protein loaded';
  document.getElementById('pdb-zone').classList.add('loaded');
  showPdbPeek(pdbContent);
  initThumb(pdbContent);
  checkReady();
}
function atomLine(num,res,ch,resNum,x,y,z){
  return 'ATOM  '+String(num).padStart(5)+'  CA  '+res+' '+ch+String(resNum).padStart(4)+'    '+String(x).padStart(8)+String(y).padStart(8)+String(z).padStart(8)+'  1.00 20.00           C';
}

// ── PROTEIN FEATURES ──
var KD_SCALE={ALA:1.8,ARG:-4.5,ASN:-3.5,ASP:-3.5,CYS:2.5,GLN:-3.5,GLU:-3.5,GLY:-0.4,HIS:-3.2,ILE:4.5,LEU:3.8,LYS:-3.9,MET:1.9,PHE:2.8,PRO:-1.6,SER:-0.8,THR:-0.7,TRP:-0.9,TYR:-1.3,VAL:4.2};
var AROM=new Set(['PHE','TYR','TRP','HIS']);
var CHG=new Set(['ARG','LYS','ASP','GLU','HIS']);
function extractProteinFeatures(pdb){
  var al=pdb.split('\n').filter(function(l){return l.startsWith('ATOM')&&l.substring(12,16).trim()==='CA'});
  if(!al.length) return{residue_count:200,hydrophobic_count:55,avg_hydrophobicity:.42,pocket_residues:38,pocket_size:475,charge_count:28,aromatic_res_count:18};
  var hy=0,tk=0,ch=0,ar=0,coords=[];
  al.forEach(function(l){
    var res=l.substring(17,20).trim();
    var kd=KD_SCALE[res]!==undefined?KD_SCALE[res]:0;
    if(kd>1.5) hy++;
    tk+=kd;
    if(CHG.has(res)) ch++;
    if(AROM.has(res)) ar++;
    var x=parseFloat(l.substring(30,38)),y=parseFloat(l.substring(38,46)),z=parseFloat(l.substring(46,54));
    if(!isNaN(x)) coords.push([x,y,z]);
  });
  var n=coords.length||1,cx=0,cy=0,cz=0;
  coords.forEach(function(c){cx+=c[0];cy+=c[1];cz+=c[2]});
  cx/=n;cy/=n;cz/=n;
  var pocket=0;
  coords.forEach(function(c){if(Math.sqrt((c[0]-cx)*(c[0]-cx)+(c[1]-cy)*(c[1]-cy)+(c[2]-cz)*(c[2]-cz))<15) pocket++;});
  return{residue_count:n,hydrophobic_count:hy,avg_hydrophobicity:parseFloat((tk/n).toFixed(4)),pocket_residues:pocket,pocket_size:parseFloat((pocket*12.5).toFixed(1)),charge_count:ch,aromatic_res_count:ar};
}

// ── LIGAND FEATURES ──
function estimateMW(s){
  var mw=0,sc=s;
  [['Cl',35.45],['Br',79.904]].forEach(function(p){var c=(sc.match(new RegExp(p[0],'g'))||[]).length;mw+=c*p[1];sc=sc.replace(new RegExp(p[0],'g'),'')});
  [['C',12.011],['N',14.007],['O',15.999],['F',18.998],['P',30.974],['S',32.06],['I',126.904]].forEach(function(p){mw+=(sc.match(new RegExp(p[0],'gi'))||[]).length*p[1]});
  return mw+(s.match(/[cC]/g)||[]).length*1.5*1.008;
}
function cHBD(s){return Math.max(0,(s.match(/\[NH\]|\[nH\]|\[OH\]/g)||[]).length+(s.match(/NH/g)||[]).length+(s.match(/OH/g)||[]).length);}
function cHBA(s){return(s.match(/[NnOo]/g)||[]).length;}
function cLogP(s){var l=0;l+=(s.match(/c/g)||[]).length*.26;l+=(s.match(/[C]/g)||[]).length*.20;l-=(s.match(/[Nn]/g)||[]).length*.74;l-=(s.match(/[Oo]/g)||[]).length*.51;l+=(s.match(/Cl/g)||[]).length*.70;l+=(s.match(/Br/g)||[]).length*.86;l+=(s.match(/F/g)||[]).length*.14;l+=(s.match(/[Ss]/g)||[]).length*.34;return parseFloat(l.toFixed(2));}
function cAro(s){var a=(s.match(/[cnos]/g)||[]).length;return a<4?0:Math.max(0,Math.round(a/6));}
function cRot(s){return Math.max(0,Math.round(((s.match(/(?<=[A-Za-z\]])(?=[A-Za-z\[])/g)||[]).length-(s.match(/\d/g)||[]).length/2-1)));}
function cHeavy(s){return(s.match(/[cCNnOoFPSIClBr]/g)||[]).length;}
function cSP3(s){var tc=(s.match(/[cC]/g)||[]).length||1,ac=(s.match(/c/g)||[]).length;return parseFloat(Math.min(1,Math.max(0,(tc-ac)/tc)).toFixed(3));}
function cTPSA(hbd,hba,ns){return parseFloat((hbd*20.23+hba*6.36+ns*12.89).toFixed(1));}
function featuresFromSMILES(smi){
  if(!smi||smi.length<2) return{mol_weight:300,hbd:2,hba:4,logp:2.0,tpsa:60,aromatic_rings:1,rot_bonds:3,frac_csp3:.4,heavy_atoms:22,lipinski_pass:1,lip_mw:true,lip_hbd:true,lip_hba:true,lip_logp:true};
  var mw=estimateMW(smi),hbd=cHBD(smi),hba=cHBA(smi),logp=cLogP(smi);
  var aro=cAro(smi),rot=cRot(smi),sp3=cSP3(smi),heavy=cHeavy(smi);
  var ns=(smi.match(/[Nn]/g)||[]).length,tpsa=cTPSA(hbd,hba,ns);
  var lm=mw<=500,ld=hbd<=5,la=hba<=10,ll=logp<=5;
  return{mol_weight:parseFloat(mw.toFixed(2)),hbd:hbd,hba:hba,logp:logp,tpsa:tpsa,aromatic_rings:aro,rot_bonds:rot,frac_csp3:sp3,heavy_atoms:heavy,lipinski_pass:(lm&&ld&&la&&ll)?1:0,lip_mw:lm,lip_hbd:ld,lip_hba:la,lip_logp:ll};
}
function featuresFromSDF(c){
  var lines=c.split('\n'),C=0,N=0,O=0,S=0,F=0,Cl=0,Br=0;
  lines.forEach(function(l){var m=l.match(/^\s+[\d.-]+\s+[\d.-]+\s+[\d.-]+\s+([A-Za-z]+)/);if(m){var el=m[1];if(el==='C')C++;else if(el==='N')N++;else if(el==='O')O++;else if(el==='S')S++;else if(el==='F')F++;else if(el==='Cl')Cl++;else if(el==='Br')Br++;}});
  var mw=C*12.011+N*14.007+O*15.999+S*32.06+F*18.998+Cl*35.45+Br*79.904+(C+N)*1.008;
  var hbd=Math.max(0,Math.round(N*.4+O*.2)),hba=N+O;
  var logp=parseFloat((C*.2-N*.7-O*.5+Cl*.7+Br*.8+S*.3).toFixed(2));
  var tpsa=cTPSA(hbd,hba,N);
  var lm=mw<=500,ld=hbd<=5,la=hba<=10,ll=logp<=5;
  return{mol_weight:parseFloat(mw.toFixed(2)),hbd:hbd,hba:hba,logp:logp,tpsa:tpsa,aromatic_rings:1,rot_bonds:3,frac_csp3:.4,heavy_atoms:C+N+O+S+F+Cl+Br,lipinski_pass:(lm&&ld&&la&&ll)?1:0,lip_mw:lm,lip_hbd:ld,lip_hba:la,lip_logp:ll};
}
function extractLigandFeatures(inp,mode){return mode==='smiles'?featuresFromSMILES(inp):featuresFromSDF(inp);}

// ── GBM PREDICTION ──
function buildFV(pf,lf){
  return[pf.residue_count,pf.hydrophobic_count,pf.avg_hydrophobicity,pf.pocket_residues,pf.pocket_size,pf.charge_count,pf.aromatic_res_count,lf.mol_weight,lf.hbd,lf.hba,lf.logp,lf.tpsa,lf.aromatic_rings,lf.rot_bonds,lf.frac_csp3,lf.heavy_atoms,lf.lipinski_pass,(pf.residue_count*lf.mol_weight)/10000,(pf.pocket_size*lf.tpsa)/10000,pf.aromatic_res_count*lf.aromatic_rings,pf.charge_count*(lf.hbd+lf.hba)];
}
var FM=[250,65,.35,45,562.5,28,18,310,2.5,5.5,2.2,72,1.4,3.8,.38,23,.78,7.75,4.05,2.52,23.1];
var FS=[130,38,.72,28,350,18,11,130,1.8,3.2,1.7,42,1.1,2.5,.22,11,.41,4.75,3.10,2.10,16.5];
var GW=[-0.001,-0.009,-0.38,-0.021,-0.0002,-0.048,-0.062,0.0005,0.09,-0.062,0.07,0.004,-0.18,0.035,.19,.008,.28,-0.0003,-0.0002,-0.09,-0.02];
function gbmPredict(fv){
  var sc=fv.map(function(v,i){return(v-FM[i])/(FS[i]||1)});
  var score=-7.2,t1=0,t2=0;
  sc.forEach(function(v,i){t1+=GW[i]*v;t2+=GW[i]*Math.tanh(v*.8)*.5;});
  score+=t1+t2*.6;
  score+=-0.8/(1+Math.exp(2*(sc[3]-1.0)));
  score+=-0.45*Math.exp(-0.5*sc[10]*sc[10]);
  score+=-0.30*Math.exp(-0.5*sc[7]*sc[7]);
  score+=-0.15*Math.max(0,sc[12]);
  score+=-0.20*Math.max(0,sc[9]);
  if(!fv[16]) score+=1.2;
  return parseFloat(Math.max(-13,Math.min(-2.5,score)).toFixed(2));
}
function s2prob(s){return parseFloat(((1/(1+Math.exp(-0.8*(s-(-7.0)))))*100).toFixed(1));}
function s2str(s){return s<=-8?'Strong':s<=-6?'Moderate':'Weak';}
function mConf(pf,lf){var c=85;if(pf.residue_count<50||pf.residue_count>1000)c-=10;if(pf.pocket_residues<5)c-=15;if(!lf.lipinski_pass)c-=10;if(lf.hba>10||lf.hbd>5)c-=5;return Math.max(40,Math.min(95,c));}
function computePrediction(pf,lf){var fv=buildFV(pf,lf),sc=gbmPredict(fv);return{docking_score:sc,binding_probability:s2prob(sc),binding_strength:s2str(sc),model_confidence:mConf(pf,lf)};}

// ── PIPELINE ──
var PIPELINE=[
  {name:'ProteinAnalysisAgent', file:'agents/protein_agent.py',        desc:'Extracting residues, pocket geometry, KD hydrophobicity',       ms:650},
  {name:'LigandAnalysisAgent',  file:'agents/ligand_agent.py',         desc:'Computing MW, HBD/HBA, LogP, TPSA, aromaticity',                ms:500},
  {name:'PredictionAgent',      file:'agents/prediction_agent.py',     desc:'Scaling 21 features, running GBM inference → docking score',   ms:800},
  {name:'InterpretationAgent',  file:'agents/interpretation_agent.py', desc:'Sigmoid binding probability, Lipinski Rule-of-Five',            ms:400},
  {name:'UIAgent',              file:'agents/ui_agent.py',             desc:'Compiling PredictionResult, rendering 3D viewer and results',   ms:250},
];
function runPrediction(){
  var smi=document.getElementById('smiles-in').value.trim();
  var ligInput=ligMode==='smiles'?smi:ligContent;
  document.getElementById('placeholder').style.display='none';
  document.getElementById('results-panel').style.display='none';
  document.getElementById('loading-panel').style.display='';
  var btn=document.getElementById('run-btn');
  btn.disabled=true; btn.classList.add('running');
  btn.innerHTML='<span class="spinner"></span>Running agents…';
  var pf=extractProteinFeatures(pdbContent);
  var lf=extractLigandFeatures(ligInput,ligMode);
  var result=computePrediction(pf,lf);
  var list=document.getElementById('agent-list');
  list.innerHTML=PIPELINE.map(function(a,i){
    return '<div class="agent-item" id="ag-'+i+'"><div class="agent-dot"></div><div style="flex:1"><div class="agent-name">'+a.name+'</div><div style="font-size:9.5px;color:var(--text3);margin-top:1px;font-family:var(--mono)">'+a.file+'</div></div><div class="agent-stat" id="astat-'+i+'">waiting</div></div>';
  }).join('');
  var delay=0;
  PIPELINE.forEach(function(a,i){
    setTimeout(function(){
      if(i>0){document.getElementById('ag-'+(i-1)).className='agent-item done';document.getElementById('astat-'+(i-1)).textContent='✓ done';}
      document.getElementById('ag-'+i).className='agent-item running';
      document.getElementById('astat-'+i).textContent=a.desc;
    },delay);
    delay+=a.ms;
  });
  setTimeout(function(){
    document.getElementById('ag-'+(PIPELINE.length-1)).className='agent-item done';
    document.getElementById('astat-'+(PIPELINE.length-1)).textContent='✓ done';
    document.getElementById('loading-panel').style.display='none';
    renderResults(result,pf,lf,ligMode==='smiles'?smi:ligFileName);
    btn.disabled=false; btn.classList.remove('running'); btn.innerHTML='Run Prediction';
  },delay+300);
}

// ── MAIN 3D VIEWER ──
var currentStyle='cartoon';
function initMainViewer(pdbStr){
  var el=document.getElementById('mol-viewer');
  if(!el) return;
  if(mainViewer){try{mainViewer.clear();}catch(e){}}
  var loader=document.getElementById('vloader');
  if(loader) loader.style.display='flex';
  setTimeout(function(){
    mainViewer=$3Dmol.createViewer($(el),{backgroundColor:'#060a10',antialias:true,alpha:true});
    mainViewer.addModel(pdbStr,'pdb');
    applyMainStyle('cartoon');
    mainViewer.zoomTo();
    mainViewer.render();
    if(loader) loader.style.display='none';
    if(window._mainRot) clearInterval(window._mainRot);
    window._mainRot=setInterval(function(){
      if(mainViewer&&!window._viewerHovered){mainViewer.rotate(.25,{x:0,y:1,z:0});mainViewer.render();}
    },50);
  },80);
}
function applyMainStyle(s){
  if(!mainViewer) return;
  currentStyle=s;
  mainViewer.setStyle({});
  mainViewer.removeAllSurfaces();
  if(s==='cartoon'){
    mainViewer.setStyle({hetflag:false},{cartoon:{color:'spectrum',opacity:.97}});
    mainViewer.setStyle({hetflag:true},{stick:{radius:.14,colorscheme:'greenCarbon'},sphere:{radius:.28,colorscheme:'greenCarbon'}});
  } else if(s==='surface'){
    mainViewer.setStyle({hetflag:false},{cartoon:{color:'spectrum',opacity:.22}});
    mainViewer.addSurface($3Dmol.SurfaceType.SAS,{opacity:.5,colorscheme:{gradient:'rwb',min:-5,max:5}},{hetflag:false});
    mainViewer.setStyle({hetflag:true},{stick:{radius:.14,colorscheme:'greenCarbon'},sphere:{radius:.28}});
  } else if(s==='ribbon'){
    mainViewer.setStyle({hetflag:false},{cartoon:{style:'ribbon',color:'spectrum',opacity:.97,thickness:.5}});
    mainViewer.setStyle({hetflag:true},{stick:{radius:.14,colorscheme:'greenCarbon'},sphere:{radius:.28}});
  } else if(s==='sphere'){
    mainViewer.setStyle({},{sphere:{colorscheme:'chainHetatm',radius:.4}});
  } else if(s==='stick'){
    mainViewer.setStyle({},{stick:{radius:.1,colorscheme:'chainHetatm'}});
  }
  mainViewer.render();
  document.querySelectorAll('.vc-btn[data-style]').forEach(function(b){b.classList.toggle('active',b.dataset.style===s)});
}
function togglePocket(){
  if(!mainViewer||!pdbContent) return;
  if(window._pocketShown){
    mainViewer.removeAllShapes();
    window._pocketShown=false;
  } else {
    var al=pdbContent.split('\n').filter(function(l){return l.startsWith('ATOM')&&l.substring(12,16).trim()==='CA'});
    var coords=al.map(function(l){return[parseFloat(l.substring(30,38)),parseFloat(l.substring(38,46)),parseFloat(l.substring(46,54))]}).filter(function(c){return!isNaN(c[0])});
    if(!coords.length) return;
    var cx=0,cy=0,cz=0;
    coords.forEach(function(c){cx+=c[0];cy+=c[1];cz+=c[2]});
    cx/=coords.length;cy/=coords.length;cz/=coords.length;
    mainViewer.addSphere({center:{x:cx,y:cy,z:cz},radius:15,color:'cyan',opacity:.07,wireframe:true});
    mainViewer.addSphere({center:{x:cx,y:cy,z:cz},radius:1.3,color:'#fbbf24',opacity:.85});
    mainViewer.render();
    window._pocketShown=true;
  }
}
function zoomPocket(){
  if(!mainViewer||!pdbContent) return;
  var al=pdbContent.split('\n').filter(function(l){return l.startsWith('ATOM')&&l.substring(12,16).trim()==='CA'});
  var coords=al.map(function(l){return[parseFloat(l.substring(30,38)),parseFloat(l.substring(38,46)),parseFloat(l.substring(46,54))]}).filter(function(c){return!isNaN(c[0])});
  if(!coords.length) return;
  var cx=0,cy=0,cz=0;
  coords.forEach(function(c){cx+=c[0];cy+=c[1];cz+=c[2]});
  cx/=coords.length;cy/=coords.length;cz/=coords.length;
  mainViewer.zoomTo({x:cx,y:cy,z:cz});
  mainViewer.render();
}

// ── RESULTS ──
