    +'<div class="metric-card"><div class="metric-label">Lipinski compliance</div><div class="metric-value" style="color:'+(lf.lipinski_pass?'var(--green)':'var(--red)')+'">'+( lf.lipinski_pass?'Pass':'Fail')+'</div><div class="metric-sub">'+(lipFails===0?'All 4 rules satisfied':lipFails+' rule(s) violated')+'</div></div>'
  +'</div>'

  +'<div class="info-card">'
    +'<div class="res-tabs">'
      +'<button class="res-tab active" onclick="switchTab(\'summary\',this)">Summary</button>'
