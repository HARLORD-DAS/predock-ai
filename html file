    +'<div class="metric-card"><div class="metric-label">Binding probability</div><div class="metric-value">'+result.binding_probability+'<span style="font-size:16px">%</span></div><div class="pbar"><div class="pfill pfill-g" style="width:'+result.binding_probability+'%"></div></div><div class="metric-sub">sigmoid(score, mid=−7.0 kcal/mol)</div></div>'
